# ══════════════════════════════════════════════
#  AIRouter v2 — .env configuration
#  Copy this to .env and fill in your keys
# ══════════════════════════════════════════════

# ── Server ──────────────────────────────────────
PORT=20130
HOST=0.0.0.0

# ── Auth ────────────────────────────────────────
# JWT_SECRET is auto-generated on first run if left empty
JWT_SECRET=
INITIAL_PASSWORD=admin123

# ── Data ────────────────────────────────────────
DATA_DIR=./data

# ══════════════════════════════════════════════
#  FREE PROVIDERS — No credit card needed!
# ══════════════════════════════════════════════

# ── OpenRouter (RECOMMENDED — 1 key, 35+ free models) ──
# Sign up: https://openrouter.ai  (no credit card)
# Free models: 200 req/day. Add $10 once -> 1000 req/day
OPENROUTER_API_KEY=

# ── Google Gemini (1500 req/day FREE) ────────────
# Sign up: https://aistudio.google.com  (no credit card)
# Models: gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
GEMINI_API_KEY=

# ── Groq (fastest inference, FREE) ───────────────
# Sign up: https://console.groq.com  (no credit card)
# Models: llama-3.3-70b, llama-4-scout, qwen3-32b, kimi-k2
GROQ_API_KEY=

# ── Cerebras (60K tokens/min FREE) ───────────────
# Sign up: https://cloud.cerebras.ai  (no credit card)
CEREBRAS_API_KEY=

# ── GitHub Models (free for any GitHub user) ─────
# Get token: https://github.com/marketplace/models
# Settings -> Developer Settings -> Personal Access Token
GITHUB_TOKEN=

# ── NVIDIA NIM (40 RPM, no daily cap, FREE) ──────
# Sign up: https://build.nvidia.com  (no credit card)
NVIDIA_API_KEY=

# ══════════════════════════════════════════════
#  PAID PROVIDERS (optional, for higher quality)
# ══════════════════════════════════════════════

# Anthropic Claude ($5 free trial on signup)
ANTHROPIC_API_KEY=

# OpenAI (no free tier, but GitHub Models covers GPT)
OPENAI_API_KEY=

# DeepSeek (5M free tokens on signup, ~$0.014/1M after)
DEEPSEEK_API_KEY=

# GLM-4 / Zhipu AI
GLM_API_KEY=

# Moonshot / Kimi
KIMI_API_KEY=

# Together AI ($100 free signup credit)
TOGETHER_API_KEY=

# Qwen / Alibaba DashScope
QWEN_API_KEY=

# Xiaomi MiMo (Token Plan or Pay-as-you-go)
# Token Plan: https://platform.xiaomimimo.com/#/console/plan-manage
# Pay-as-you-go: https://platform.xiaomimimo.com/#/console/api-keys
# Base URL override (optional, default: pay-as-you-go)
# MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_API_KEY=
